# X API OAuth 2.0 Configuration
# Get your Client ID from console.x.com → Apps → Your App → Settings
X_CLIENT_ID=your-client-id-here

# OAuth callback (default works, don't change unless you know why)
X_REDIRECT_URI=http://localhost:8080/callback

# Required scopes (don't change)
X_SCOPES=tweet.read users.read bookmark.read offline.access

# Max bookmarks to fetch per run (default 200, max 800)
FETCH_LIMIT=200
